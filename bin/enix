nix_shells_folder="$HOME/playin/nixos_files/shells/"

export NIX_CONFIG="extra-experimental-features = flakes nix-command"

flake_shell="";

if [ -z ${1} ]; 
then
  flake_shell=$( ls $nix_shells_folder | grep -v -e '.nix$' | fzf );
else
  flake_shell=$1 
fi

cd "$nix_shells_folder/$flake_shell";

if [ -z $(nix flake show --json 2>/dev/null | jq 'keys | .[]'  -r | grep 'apps')  ]; then
  echo develop 
  nix develop .
else
  echo run 
  nix run .
fi

