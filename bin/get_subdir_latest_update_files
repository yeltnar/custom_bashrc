#!/bin/bash

# Get current time in seconds since epoch for age calculation
current_time=$(date +%s)

# Initialize an empty JSON array string using jq
json_output="[]"

while read -r subdir; do
    dir_name=$(basename "$subdir")
    
    # Get the raw modification time in seconds (%T@) and formatted date (%T+)
    file_info=$(find "$subdir" -maxdepth 1 -type f -printf "%T+ %T@\n" 2>/dev/null | sort -r | head -n 1)
    
    if [ -n "$file_info" ]; then
        latest_date=$(echo "$file_info" | awk '{print $1}')
        epoch_time=$(echo "$file_info" | awk '{print $2}' | cut -d. -f1)
        
        # Calculate age in seconds
        age_seconds=$((current_time - epoch_time))
        
        # Convert seconds into a readable "age_txt" string
        if [ $age_seconds -ge 86400 ]; then
            age_txt="$((age_seconds / 86400))d ago"
        elif [ $age_seconds -ge 3600 ]; then
            age_txt="$((age_seconds / 3600))h ago"
        elif [ $age_seconds -ge 60 ]; then
            age_txt="$((age_seconds / 60))m ago"
        else
            age_txt="${age_seconds}s ago"
        fi
        
        # Use jq to append the populated object to our array
        json_output=$(echo "$json_output" | jq \
            --arg date "$latest_date" \
            --arg age_txt "$age_txt" \
            --argjson age "$age_seconds" \
            --arg dir "$dir_name" \
            '. += [{date: $date, age_txt: $age_txt, age: $age, directory: $dir}]')
    else
        # Use jq to append an empty/null object to our array
        json_output=$(echo "$json_output" | jq \
            --arg dir "$dir_name" \
            '. += [{date: null, age_txt: null, age: null, directory: $dir}]')
    fi

# Feed the find output directly into the while loop
# done < <(find . -mindepth 1 -maxdepth 1 -type d ! -name "_*")
done < <(find . -mindepth 1 -maxdepth 1 -type d)

# Print the final formatted JSON array
echo "$json_output" | jq

echo -e "\nolder than a day..."
echo "$json_output" | jq '[.[] | select(.age > 86400)]'

# echo "$json_output" | jq '[.[] | select(.age < 86400)]'


echo -e "\nlengh dif..."
printf "$json_output" | jq 'length' ; 
printf "$json_output" | jq '[.[] | select(.age > 86400)] | length'
echo