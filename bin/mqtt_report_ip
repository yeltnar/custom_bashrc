source "$(dirname "$0")/_report_ip_shared.sh"

if [ -z "$NO_SOURCE" ]; then
  source "$bashrc_folder/gitignore/mqtt_report_ip.env"
fi

if [ -z "$mqtt_endpoint" ]; then
  echo "\$mqtt_endpoint is not set; Check $bashrc_folder/gitignore/mqtt_report_ip.env" 1>&2;
  exit 1;
fi

# send message 
mqtt_location="device_report/status/$device_name"
mqtt_location_ok="device_report/ok/$device_name"

set -x
mosquitto_pub -r -h "$mqtt_endpoint" -t "$mqtt_location" -m "$device_report_json"
mosquitto_pub -x 60 -h "$mqtt_endpoint" -t "$mqtt_location_ok" -m "ok"
set +x

if [ -s "/tmp/mqtt_report_curl_error" ];then
	mv /tmp/mqtt_report_curl_error ~/cron/
fi

